# Настройки для TeamSpeak контейнера
TS3_CONTAINER_NAME=teamspeak              # Имя контейнера для TeamSpeak
TS3_PORT_UDP=9987                         # Порт для голосового трафика TeamSpeak
TS3_PORT_FILE=30033                       # Порт для передачи файлов
TS3SERVER_LICENSE=accept                  # Принятие лицензии (accept | view)
# Путь к каталогу с licensekey.dat (по умолчанию /var/ts3server — данные в volume)
# TS3SERVER_LICENSEPATH=/var/ts3server